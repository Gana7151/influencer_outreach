    {
      "parameters": {
        "agent": "conversationalAgent",
        "promptType": "define",
        "text": "=Research this potential influencer and extract structured data.\n\nURL: {{ $json.url }}\nTitle: {{ $json.title }}\nText: {{ $json.text }}\nHighlights: {{ $json.highlights }}\n\nReturn ONLY a JSON object:\n{\n  \"name\": \"Full name\",\n  \"email\": \"email or empty string\",\n  \"platform\": \"main platform\",\n  \"channel_name\": \"channel name\",\n  \"channel_url\": \"channel URL\",\n  \"subscribers\": 0,\n  \"linkedin_url\": \"linkedin URL or empty string\",\n  \"niche\": \"trading niche\",\n  \"recent_topics\": \"topic1, topic2, topic3\",\n  \"meets_criteria\": true\n}",
        "options": {
          "systemMessage": "You are a lead research specialist for CrowdWisdomTrading. Extract structured contact info from influencer profiles. Be accurate. Use empty strings if info is unavailable."
        }
      },
      "id": "a9bac9aa-be3e-4bd9-aca1-ba90a56c36e3",
      "name": "AI Research Lead",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        1500,
        300
      ]
    },
    {
      "parameters": {
        "content": "🤖 AI AGENT — RESEARCH LEAD\n\n>>> LLM SETUP (choose one) <<<\n\nOPTION A — OpenRouter:\n1. https://openrouter.ai (free $1)\n2. Add sub-node: OpenAI Chat Model\n3. Base URL: https://openrouter.ai/api/v1\n4. Model: google/gemini-2.0-flash-exp:free\n\nOPTION B — Gemini:\n1. https://aistudio.google.com/apikey\n2. Add sub-node: Google Gemini Chat Model\n3. Model: gemini-2.0-flash\n\n>>> TOOLS (sub-nodes) <<<\n• HTTP Request Tool\n• Or Tavily Search tool",
        "width": 400,
        "height": 320
      },
      "id": "ca3dbca2-c88f-4714-a7af-0acc88f9f1c2",
      "name": "Sticky Note - 🤖 AI AGENT — RESEAR",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        1470,
        -40
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse the AI agent's JSON output\nconst output = $input.first().json.output || $input.first().json.text || '';\nlet parsed;\ntry {\n  // Try to extract JSON from the output\n  const jsonMatch = output.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(jsonMatch ? jsonMatch[0] : output);\n} catch(e) {\n  parsed = {\n    name: 'Unknown',\n    email: '',\n    platform: '',\n    channel_name: '',\n    channel_url: '',\n    subscribers: 0,\n    linkedin_url: '',\n    niche: '',\n    recent_topics: '',\n    meets_criteria: false,\n    parse_error: e.message\n  };\n}\nreturn [{ json: parsed }];"
      },
      "id": "2fc95cff-86fe-4760-95a4-6ca007838ee3",
      "name": "Parse AI Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1800,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.meets_criteria }}",
              "value2": true
            }
          ]
        }
      },
      "id": "14354906-bc16-48a7-91cf-db1b4997d769",
      "name": "IF Qualified",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [

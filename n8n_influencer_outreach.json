    },
    {
      "parameters": {
        "content": "✅ QUALIFICATION CHECK\n\nChecks meets_criteria from AI output.\n\nTRUE → CRM + Email\nFALSE → Log as unqualified\n\n✅ NO API NEEDED",
        "width": 340,
        "height": 240
      },
      "id": "c00a7090-7f5f-4dc1-bd79-2868c36e5d2b",
      "name": "Sticky Note - ✅ QUALIFICATION CHEC",
      "type": "n8n-nodes-base.stickyNote",

        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ query: $json.search_query, type: 'neural', useAutoprompt: true, numResults: 15, contents: { text: true, highlights: true } }) }}",
        "options": {}
      },
      "id": "0b09e1d1-3bf1-4452-943f-afce35849fda",
      "name": "Exa Search",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        600,
        300
      ]
    },
    {
      "parameters": {
        "content": "🔍 EXA AI SEARCH\n\n>>> API KEY NEEDED <<<\n\n1. Sign up: https://exa.ai\n2. Free: $5 credit\n3. Dashboard → API Keys\n4. Replace YOUR_EXA_API_KEY_HERE\n\nALT — Tavily Search:\n1. https://tavily.com (free 1000/mo)\n2. Change URL to: https://api.tavily.com/search\n3. Body: {api_key, query, max_results}",
        "width": 380,
        "height": 300
      },
      "id": "aee9a044-eae9-44cb-8a49-c9c8f014057d",
      "name": "Sticky Note - 🔍 EXA AI SEARCH\n\n>>",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        570,
        -20
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse Exa search results into individual items\nconst body = $input.first().json;\nconst results = body.results || body.data || [];\n\nif (!results.length) {\n  return [{ json: { error: 'No results found', query: body } }];\n}\n\nreturn results.map(r => ({\n  json: {\n    url: r.url || '',\n    title: r.title || '',\n    text: (r.text || '').substring(0, 1000),\n    highlights: Array.isArray(r.highlights) ? r.highlights.join(' | ') : '',\n    score: r.score || 0\n  }\n}));"
      },
      "id": "b02afa90-8cc6-4e8a-b678-471bfd64d270",
      "name": "Parse Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "content": "📦 PARSE RESULTS\n\nCode node that extracts individual leads from the Exa response.\n\nConverts the results array into separate items for processing.\n\n✅ NO API NEEDED",
        "width": 340,
        "height": 260
      },
      "id": "d492db4f-a352-4f55-84c6-aaf72183eb4e",
      "name": "Sticky Note - 📦 PARSE RESULTS\n\nCo",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        870,
        0
      ]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "97622522-3f8b-466e-a473-8291758865f6",
      "name": "Loop Over Leads",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1200,
        300
      ]
    },
    {
      "parameters": {
        "content": "🔄 LOOP\n\nProcesses 1 lead at a time.\n• Error isolation per lead\n• Rate limit safe\n\n⚠️ Enable 'Continue On Fail' in node Settings for production!\n\n✅ NO API NEEDED",
        "width": 340,
        "height": 260
      },
      "id": "dc9caeae-71d5-4ebf-bf48-7a9be2afe325",
      "name": "Sticky Note - 🔄 LOOP\n\nProcesses 1",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        1170,
        0
